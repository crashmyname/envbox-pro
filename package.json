{
  "name": "envbox-pro",
  "version": "3.0.0",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win",
    "build:linux": "electron-builder --linux",
    "build:mac": "electron-builder --mac",
    "build:all": "electron-builder --win --linux --mac",
    "build:portable": "electron-builder --win portable"
  },
  "keywords": [],
  "author": "Fadli Azka P",
  "license": "ISC",
  "description": "EnvBox Pro - Enterprise Environment Manager",
  "devDependencies": {
    "@tailwindcss/cli": "^4.3.2",
    "electron": "^28.0.0",
    "electron-builder": "^24.13.3",
    "electron-rebuild": "^3.2.9",
    "tailwindcss": "^3.4.19"
  },
  "dependencies": {
    "@tabler/icons-webfont": "^3.44.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "amqplib": "^0.10.3",
    "ansi-to-html": "^0.7.2",
    "archiver": "^6.0.0",
    "axios": "^1.6.0",
    "bull": "^4.12.0",
    "chokidar": "^3.6.0",
    "compression": "^1.7.4",
    "cron": "^3.1.7",
    "electron-context-menu": "^3.6.1",
    "electron-store": "^8.1.0",
    "electron-updater": "^6.1.0",
    "extract-zip": "^2.0.1",
    "fs-extra": "^11.2.0",
    "http-proxy": "^1.18.1",
    "ioredis": "^5.3.2",
    "keytar": "^7.9.0",
    "mysql2": "^3.9.0",
    "node-cron": "^3.0.3",
    "node-machine-id": "^1.1.12",
    "node-pty": "^1.1.0",
    "node-schedule": "^2.1.1",
    "pg": "^8.11.0",
    "pidusage": "^3.0.2",
    "sql.js": "^1.9.0",
    "systeminformation": "^5.22.0",
    "tar": "^6.2.0",
    "uuid": "^9.0.0",
    "winston": "^3.11.0"
  },
  "build": {
    "appId": "com.envbox.pro",
    "productName": "EnvBox Pro",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "src/**/*",
      "modules/**/*",
      "environments/**/*",
      "projects/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "resources/vc_redist.x64.exe",
        "to": "resources/vc_redist.x64.exe"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        },
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ],
      "icon": "resources/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "linux": {
      "target": [
        {
          "target": "deb",
          "arch": ["x64"]
        },
        {
          "target": "AppImage",
          "arch": ["x64"]
        }
      ],
      "icon": "resources/icon.png",
      "category": "Development"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": ["x64", "arm64"]
        }
      ],
      "icon": "resources/icon.icns",
      "category": "public.app-category.developer-tools"
    }
  }
}
